#pragma package(smart_init)

using namespace std;

__fastcall tPlants::tPlants(TComponent* Owner, String type, int top, int left) : TImage(Owner)
{
	this->Parent = (TWinControl*)Owner;
	this->plantType = type;

	this->Top = top;
	this->Left = left;

	if (type == "Peashooter") {
		this->Picture->LoadFromFile("peashooter.jpg");
		this->plantHp = 6;
		this->cost = 100;
		this->cooldownTime = 7500;
		this->attackPower = 1;
		this->attackSpeed = 1500;
		this->shooting = true;

    }
	else if (type == "Sunflower") {
		this->Picture->LoadFromFile("sunflower.jpg");
		this->plantHp = 6;

    }
	else if (type == "Wall-nut") {
        this->Picture->LoadFromFile("wallnut.jpg");

    }

    this->Width = 50;
    this->Height = 70;
	this->Visible = true;
    this->Stretch = true;
    this->BringToFront();

}