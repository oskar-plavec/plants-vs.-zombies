#pragma hdrstop

#include "tZombie.h"
#include "Unit1.h"
//---------------------------------------------------------------------------
#pragma package(smart_init)

using namespace std;

__fastcall tZombie::tZombie(TComponent* Owner, String type, int top) : TImage(Owner)
{
	this->Parent = (TWinControl*)Owner;
	this->zombieType = type;

	this->Top = top;
	this->Left = 1000;

    this->Width = 70;
	this->Height = 110;

	if (type == "Normal") {
		this->Picture->LoadFromFile("normalZombie.png");
		this->zombieHp = 100;
		this->attackPower = 20;
		this->attackInterval = 500;
		this->speed = 1;

	}
	else if (type == "Cone") {
		this->Picture->LoadFromFile("coneZombie.png");
		this->zombieHp = 190;
		this->attackPower = 20;
		this->attackInterval = 500;
		this->speed = 1;
		this->Height = 120;
    }

	this->Visible = true;
    this->Stretch = true;
	this->BringToFront();
}
//------------------------------------------------------------------------------
void tZombie::moveZombie(vector<nZombie> &zombies, int i)
{
	if (this->Left >= 0) {
	   this->Left -= this->speed;
	}
	else {
		zombies.erase(zombies.begin() + i);
		delete this;

	}

}
void tZombie::dealDamageToZombie(vector<nZombie> &zombies, vector<tProjectile*> &projectile, tProjectile* pro, int z, int p, int damage)
{
	if (damage > 0) {
		this->zombieHp -= damage;
		if (this->zombieHp <= 0) {
		   delete zombies[z].biteTimer;
		   zombies.erase(zombies.begin() + z);
		   delete this;
		}
		projectile.erase(projectile.begin() + p);
		delete pro;
	}
}
//------------------------------------------------------------------------------
int tZombie::getZombieHp()
{	return this->zombieHp;}
int tZombie::getAttackPower()
{	return this->attackPower;}
int tZombie::getAttackInterval()
{	return this->attackInterval;}
float tZombie::getSpeed()
{ 	return this->speed; }
//------------------------------------------------------------------------------
String tZombie::getZombieType()
{	return this->zombieType;}
