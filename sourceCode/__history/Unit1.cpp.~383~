void __fastcall TForm1::OnCreate(TObject *Sender)
{
	loadBackground("grassGrit.jpg");
	int tempTop[] = {115, 213, 306, 404, 503, 605};
	int tempLeft[] = {250, 345, 425, 503, 580, 668, 748, 825, 902, 990};

	for (int i = 0; i < ROW+1; i++) {
		topLimit[i] = tempTop[i];
	}
	for (int i = 0; i < COL+1; i++) {
		leftLimit[i] = tempLeft[i];
    }

	nPlant emptyPlant;
	emptyPlant.plant = nullptr;
	emptyPlant.projectile.clear();
	emptyPlant.shotTimer = nullptr;
	for (int r = 0; r < ROW; r++) {
		for (int c = 0; c < COL; c++) {
			this->plantList[r][c] = emptyPlant;
		}
	}
	srand(time(nullptr)); // for rand()
}
void __fastcall TForm1::OnDestroy(TObject *Sender)
{
  for (int i = 0; i < this->zombies.size(); i++) {
	  delete this->zombies[i].zombie;
	  this->zombies[i].biteTimer = nullptr;
  }
  this->zombies.clear();

  for (int r = 0; r < ROW; r++) {
	  for (int c = 0; c < COL; c++) {
		  delete this->plantList[r][c].plant;
		  for (int j = 0; j < this->plantList[r][c].projectile.size(); j++) {
					 delete this->plantList[r][c].projectile[j];
		  }
          this->plantList[r][c].projectile.clear();
		  this->plantList[r][c].shotTimer = nullptr;
	  }
  }
}
