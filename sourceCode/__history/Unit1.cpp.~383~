void __fastcall TForm1::SunDropClick(TObject *Sender)
{
	sunDropActive = false;

    int targetX = 30;
	int targetY = 30;
	int deltaX = targetX - SunDrop->Left;
	int deltaY = targetY - SunDrop->Top;
	int distance = sqrt((deltaX * deltaX) + (deltaY * deltaY));

	int stepsRemaining = distance / 25;
	if (stepsRemaining <= 0) stepsRemaining = 1;

	int stepX = deltaX / stepsRemaining;
	int stepY = deltaY / stepsRemaining;

	for (int i = 0; i < stepsRemaining; i++) {
        SunDrop->Left += stepX;
		SunDrop->Top += stepY;
		SunDrop->BringToFront();
        Application->ProcessMessages();
		Sleep(15);
	}

		SunDrop->Visible = false;
		changeSunCount(25);
}
void TForm1::dropSun()
{
	int minVal = leftLimit[0];
	int maxVal = leftLimit[COL];

	int randomLeft = minVal + (rand() % (maxVal - minVal + 1));

	SunDrop->Top = 0;
	SunDrop->Left = randomLeft;
	SunDrop->Visible = true;
	this->sunDropActive = true;
}
void TForm1::sunDropAnimation()
{
	if (this->sunDropActive) {
		SunDrop->Top += 2;
		SunDrop->BringToFront();
		if (SunDrop->Top >= 650) {
			this->sunDropActive = false;
			SunDrop->Top = 0;
			SunDrop->Visible = false;
		}
	}
}
void __fastcall TForm1::SunDropTimerTimer(TObject *Sender)
{
	dropSun();
}
