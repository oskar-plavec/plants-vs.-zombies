void TForm1::createProjectile(nPlant &plantNode)
{
	if (plantNode.plant->getShooting()) {
		if (plantNode.plant->getPlantType() != "Sunflower") {
		  tProjectile* newProjectile = new tProjectile(this, plantNode.plant);
		  plantNode.projectile.push_back(newProjectile);
		}
		else {
			if (plantNode.projectile.size() == 0) {
			  tProjectile* newProjectile = new tProjectile(this, plantNode.plant);
			  plantNode.projectile.push_back(newProjectile);
			}
		}
	}
}
void TForm1::shotAnimation()
{
	for (int r = 0; r < ROW; r++) {
		for (int c = 0; c < COL; c++) {
			 for (int i = 0; i < this->plantList[r][c].projectile.size(); i++) {
				 this->plantList[r][c].projectile[i]->moveProjectile(this->plantList[r][c].projectile, i);
			 }
		}
	}
}
void TForm1::removeProjectile(tPlants* originPlant, tProjectile* projectile)
{
  for (int r = 0; r < ROW; r++) {
	  for (int c = 0; c < COL; c++) {
		  if (this->plantList[r][c].plant == originPlant) {
			  for (int i = 0; i < this->plantList[r][c].projectile.size(); i++) {
				 if (this->plantList[r][c].projectile[i] == projectile) {
					//showMessage("projectile removed");
					this->plantList[r][c].projectile[i] = nullptr;
					this->plantList[r][c].projectile.erase(this->plantList[r][c].projectile.begin() + i);
				 }
				 return;
			  }
		  }
	  }
  }
}
void __fastcall TForm1::shootProjectile(TObject *Sender)
{
	for (int r = 0; r < ROW; r++){
	   for (int c = 0; c < COL; c++) {
		 if (this->plantList[r][c].shotTimer == Sender){
			createProjectile(this->plantList[r][c]);
			return;
		 }
		 if (this->plantList[r][c].plant->getPlantType() == "Chomper") {
			this->plantList[r][c].plant->changePicture("chomper.png");
			this->plantList[r][c].shotTimer->Enabled = false;
		 }
	   }
	}
}
void __fastcall TForm1::OnAnimationTimer(TObject *Sender)
{
	shotAnimation();
	sunDropAnimation();
	for (int r = 0; r < ROW; r++) {
		for (int c = 0; c < COL; c++) {
		  if (this->plantList[r][c].plant != nullptr) {
			if (this->plantList[r][c].plant->getShooting()) {
				 if (checkForZombieInLane(this->plantList[r][c])) {
					  this->plantList[r][c].shotTimer->Enabled = true;
				 }
				 else this->plantList[r][c].shotTimer->Enabled = false;
			}
		  }

		  for (int i = 0; i < zombies.size(); i++) {
			 if (this->plantList[r][c].plant != nullptr) {
				 if (this->plantList[r][c].plant->getPlantType() == "Chomper" && this->plantList[r][c].shotTimer->Enabled == false) {
					if (checkForZombie(this->zombies[i].zombie, r, c)) {
					   this->plantList[r][c].plant->eatZombie(this->plantList[r][c]);
					   delete zombies[i].zombie;
					   delete zombies[i].biteTimer;
					   zombies.erase(zombies.begin() + i);
					}
				 }
			 }
			 for (int j = 0; j < this->plantList[r][c].projectile.size(); j++) {
				 if (this->checkForHit(this->zombies[i].zombie, this->plantList[r][c].projectile[j])) {
					this->zombies[i].zombie->dealDamageToZombie(this->zombies, this->plantList[r][c].projectile, this->plantList[r][c].projectile[j], i, j, this->plantList[r][c].projectile[j]->getDamage());
				 }
			 }
			 if (this->plantList[r][c].plant != nullptr) {
				 if (checkForPlant(this->zombies[i].zombie, r, c)) {
					this->zombies[i].biteTimer->Enabled = true;
					this->zombies[i].rContact = r;
					this->zombies[i].cContact = c;
				 }
			 }
		  }
		}
	}

}
