void __fastcall TForm1::backgroundClick(TObject *Sender)
{
	int top = 0;
	int left = 0;
	int row = 0;
	int col = 0;

	int x = Mouse->CursorPos.x - (this->Left);
	int y = Mouse->CursorPos.y - (this->Top);

	//ShowMessage(IntToStr(y) + ", " + IntToStr(x));
	if (this->plantType != '\0') {

	   if ( this->checkCursorPos(x, y, row, col, top, left) ) {
		  if (this->plantList[row][col].plant == nullptr) {
			tPlants* newPlant = new tPlants(this, this->plantType, top, left);
			nPlant nodePlant;
			nodePlant.plant = newPlant;

			nodePlant.shotTimer = new TTimer(this);
			nodePlant.shotTimer->Interval = nodePlant.plant->getAttackInterval();
			nodePlant.shotTimer->OnTimer = shootProjectile;
			nodePlant.shotTimer->Enabled = false;

			this->plantList[row][col] = nodePlant;
			changeSunCount(nodePlant.plant->getCost()*-1);
			//this->plantType = '\0';
		  }
		  else showMessage("You can't plant there");
	   }
	   else showMessage("You can't plant there");
	}
}
