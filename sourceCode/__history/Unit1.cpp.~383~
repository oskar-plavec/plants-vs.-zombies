void TForm1::loadBackground(String fileName)
{
		this->background->Left = 0;
		this->background->Top = 0;
		this->background->AutoSize = true;
		this->background->Picture->LoadFromFile(fileName);
		this->background->SendToBack();
		this->background->Visible = true;
		this->background->Stretch = true;
}
