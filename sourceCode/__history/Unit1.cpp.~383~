void __fastcall TForm1::bitePlant(TObject *Sender)
{
	int r, c;
	for (int i = 0; i < this->zombies.size(); i++) {
		r = this->zombies[i].rContact;
		c = this->zombies[i].cContact;
		if (this->zombies[i].biteTimer == Sender) {
		  if (this->plantList[r][c].plant != nullptr) {
			if (!this->plantList[r][c].plant->dealDamageToPlant(this->zombies[i].zombie->getAttackPower()) ) {
				this->plantList[r][c].shotTimer->Enabled = false;
				this->plantList[r][c].plant = nullptr;
				for (int j = 0; j < this->plantList[r][c].projectile.size(); j++) {
					 delete this->plantList[r][c].projectile[j];
				}
				this->plantList[r][c].projectile.clear();
				this->plantList[r][c].shotTimer = nullptr;
				delete this->plantList[r][c].shotTimer;
				this->zombies[i].biteTimer->Enabled = false;

				//this->zombies[i].zombie->Picture->LoadFromFile("normalZombie.png");
			}
			//else this->zombies[i].zombie->Picture->LoadFromFile("eatingZombie.png");
		  }
		  else  this->zombies[i].biteTimer->Enabled = false;
		}
	}
}
void __fastcall TForm1::ZombieSpawnTimerTimer(TObject *Sender)
{
	 int minVal = topLimit[0];
	 int maxVal = topLimit[ROW];

	 int randomTop = minVal + (rand() % (maxVal - minVal + 1));

	 int row = 0;
	 for (int r = 0; r < ROW; r++) {
		if (randomTop >= this->topLimit[r] && randomTop <= this->topLimit[r+1]) {
			randomTop = this->topLimit[r] - 40;
			row = r;
			break;
		}
	 }
	 String zombieType = "Normal";
	 if (this->zombiesTotal >= 4 && this->zombiesTotal < 15) {
		 int randNum = (rand() % 3) + 1;
		 switch (randNum) {
			 case 1: zombieType = "Normal";
					 break;
			 case 2: zombieType = "Cone";
					 break;
             case 3: zombieType = "Normal";
					 break;
         default:
			 zombieType = "Normal";
		 }
	 }
	 if (this->zombiesTotal >= 15) {
		 int randNum = (rand() % 3) + 1;
		 switch (randNum) {
			 case 1: zombieType = "Normal";
					 break;
			 case 2: zombieType = "Cone";
					 break;
			 case 3: zombieType = "Bucket";
					 break;
         default:
			 zombieType = "Normal";
		 }
	 }

	 tZombie* newZombie = new tZombie(this, zombieType, randomTop);
	 nZombie newNZombie;
	 newNZombie.zombie = newZombie;
	 newNZombie.biteTimer = new TTimer(this);
	 newNZombie.biteTimer->Interval = newNZombie.zombie->getAttackInterval();
	 newNZombie.biteTimer->OnTimer = bitePlant;
	 newNZombie.biteTimer->Enabled = false;
	 this->zombies.push_back(newNZombie);
	 this->zombiesTotal++;

     //1.3^(x-10)+2

	 if (this->minTime < this->maxTime && 10000-(this->zombiesTotal*400) > 400) {
		 this->minTime = 10000-(this->zombiesTotal*400);
		 this->maxTime = 20000-(this->zombiesTotal*700);
	 }
	 else {
		 if (10000-(this->zombiesTotal*400) > 300) {
			this->minTime = 10000-(this->zombiesTotal*400);
			this->maxTime = 15000-(this->zombiesTotal*400);
         }
		 else {
			this->minTime = 500;
			this->maxTime = 1500;
		 }
	 }

     int randomTime = this->minTime + (rand() % (this->maxTime - this->minTime + 1));

	 ZombieSpawnTimer->Interval = randomTime;

}
