bool TForm1::checkForHit(tZombie* zombie, tProjectile* projectile)
{
	int zomLeft = zombie->Left+40;
	int zomTop = zombie->Top+40;
	int proLeft = projectile->Left+20;
	int proTop = projectile->Top+20;

	int rowZom = 0;
	int rowPro = 0;

	for (int i = 0; i < ROW; i++) {
		if (zomTop >= this->topLimit[i] && zomTop <= this->topLimit[i+1]) {
			rowZom = i;
		}
		if (proTop >= this->topLimit[i] && proTop <= this->topLimit[i+1]) {
			rowPro = i;
		}
	}

	int tolerance = 7;

	if (rowZom == rowPro) {
		if (zomLeft > proLeft-tolerance && zomLeft < proLeft+tolerance) {
			//showMessage("hit");
			return true;
		}
		else return false;
	}
	else return false;
}
bool TForm1::checkForZombieInLane(nPlant &plantNode)
{
	if (plantNode.plant->getPlantType() == "Sunflower") {
        return true;
	}
	int plantLeft = plantNode.plant->Left;
	int plantTop = plantNode.plant->Top+50;

	int rowPla = 0;
	for (int r = 0; r < ROW; r++) {
        if (plantTop >= this->topLimit[r] && plantTop <= this->topLimit[r+1]) {
			rowPla = r;
		}
	}

	int zomTop;
	int rowZom = -1;
	for (int i = 0; i < this->zombies.size(); i++) {
		zomTop = this->zombies[i].zombie->Top+50;
		for (int r = 0; r < ROW; r++) {
			if (zomTop >= this->topLimit[r] && zomTop <= this->topLimit[r+1]) {
				rowZom = r;
			}
			if (rowZom == rowPla && this->zombies[i].zombie->Left >= plantLeft) {
			   return true;
			}
		}
	}
	return false;
}
bool TForm1::checkForPlant(tZombie* zombie, int rowPla, int colPla)
{
	int zomLeft = zombie->Left+20;
	int zomTop = zombie->Top+45;

	int rowZom = -1;
	int colZom = -1;

	for (int i = 0; i < ROW; i++) {
		if (zomTop >= this->topLimit[i] && zomTop <= this->topLimit[i+1]) {
			for (int j = 0; j < COL; j++) {
			   if (zomLeft >= this->leftLimit[j] && zomLeft <= this->leftLimit[j+1]) {
				  colZom = j;
			   }
			}
			rowZom = i;
		}
	}

	if (rowZom == rowPla && colZom == colPla) {
	   return true;
	}
	else return false;
}
bool TForm1::checkForZombie(tZombie* zombie, int rowPla, int colPla)
{
	int zomLeft = zombie->Left+20;
	int zomTop = zombie->Top+45;

	int rowZom = -1;
	int colZom = -1;

	for (int i = 0; i < ROW; i++) {
		if (zomTop >= this->topLimit[i] && zomTop <= this->topLimit[i+1]) {
			for (int j = 0; j < COL; j++) {
			   if (zomLeft >= this->leftLimit[j] && zomLeft <= this->leftLimit[j+1]) {
				  colZom = j;
			   }
			}
			rowZom = i;
		}
	}

	if (rowZom == rowPla && colZom == colPla) {
	   return true;
	}
	else return false;
}
