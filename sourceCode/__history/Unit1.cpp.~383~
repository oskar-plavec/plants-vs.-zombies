bool TForm1::checkColumnCursorPos(int x, int c, int &col, int &left)
{
	if (x >= this->leftLimit[c] && x <= this->leftLimit[c+1]) {
		col = c;
		left = this->leftLimit[c];
		return true;
	}
	return false;
}
bool TForm1::checkCursorPos(int x, int y, int &row, int &col, int &top, int &left)
{
	bool result = false;
	bool result2 = false;
	for (int r = 0; r < ROW; r++) {
		if (y >= this->topLimit[r] && y <= this->topLimit[r+1]) {
			for (int c = 0; c < COL; c++) {
				if (checkColumnCursorPos(x, c, col, left)) {
					result2 = true;
					break;
                }
			}
			row = r;
			top = this->topLimit[r] - 15;
			if (result2) {
			  result = true;
			}
			break;
		}
	}
	return result;
}
